#!/bin/bash
LOG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/info.log"

if sudo find / -maxdepth 1 -name "*easytier.log*" -type f | grep -q .; then
    sudo find / -maxdepth 1 -name "*easytier.log*" -type f -exec rm -f {} \;
fi

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# --- 生成默认toml配置 ---
UUID=$(cat /proc/sys/kernel/random/uuid)
CONFIG_TEMPLATE="${TRIM_APPDEST}/template/default.tpl"
CONFIG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/config/default.toml"

if [ -f "$CONFIG_FILE" ]; then
    log_msg "默认配置文件已存在，跳过生成"
else
    sed \
      -e "s|\${CONFIG_NAME}|$config_name|g" \
      -e "s|\${CONFIG_SECRET}|$config_secret|g" \
      -e "s|\${PEER_URL}|$peer_url|g" \
      -e "s|\${UUID_ID}|$UUID|g" \
      "${CONFIG_TEMPLATE}" > "$CONFIG_FILE" 2>/dev/null
    log_msg "已生成默认配置文件"
fi

exit 0
