#!/bin/bash
LOG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# --- 安装时预生成toml配置 ---
UUID=$(cat /proc/sys/kernel/random/uuid)
CONFIG_TEMPLATE="${TRIM_APPDEST}/template/config.tpl"
CONFIG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/config/$UUID.toml"

if ls "${TRIM_DATA_SHARE_PATHS%%:*}/config/"*.toml 2>/dev/null | grep -q .; then
    log_msg "配置文件已存在，跳过生成"
else
    sed \
      -e "s|\${CONFIG_NAME}|$config_name|g" \
      -e "s|\${CONFIG_SECRET}|$config_secret|g" \
      -e "s|\${PEER_URL}|$peer_url|g" \
      -e "s|\${UUID_ID}|$UUID|g" \
      "${CONFIG_TEMPLATE}" > "$CONFIG_FILE" 2>/dev/null
    log_msg "已预生成配置文件"
fi

exit 0