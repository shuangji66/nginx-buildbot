#!/bin/bash
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
LOG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/data/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
KOMGA_CONFIGDIR="${TRIM_DATA_SHARE_PATHS%%:*}/data" 
KOMGA_JAR="${TRIM_APPDEST}/komga.jar"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

get_java_cmd() {
    if [ -x "/var/apps/java-21-openj9/target/bin/java" ]; then
        echo "/var/apps/java-21-openj9/target/bin/java"
        return
    fi
    
    if [ -x "/var/apps/java-21-openjdk/target/bin/java" ]; then
        echo "/var/apps/java-21-openjdk/target/bin/java"
        return
    fi
    
    echo ""
}

start_process() {
    if status; then
        return 0
    fi

    JAVA_CMD=$(get_java_cmd)
    if [ -z "$JAVA_CMD" ]; then
        echo "未找到Java! 先安装java-21-openj9或java-21-openjdk" > ${TRIM_TEMP_LOGFILE}
        return 1
    fi
    log_msg "Java: ${JAVA_CMD}"
    # 设置最大Java可用内存
    JAVA_OPTS="-Xmx2g"
    # 设置字符编码，解决中文文件名问题
    JAVA_OPTS="${JAVA_OPTS} -Dfile.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.jnu.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.stdout.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.stderr.encoding=UTF-8"
    # 禁用 JMX 以避免 cgroup v2 兼容性问题
    JAVA_OPTS="${JAVA_OPTS} -Dspring.jmx.enabled=false"
    # 构建CMD
    CMD="${JAVA_CMD} ${JAVA_OPTS} -jar ${KOMGA_JAR}"
    CMD="${CMD} --komga.config-dir="${KOMGA_CONFIGDIR}""
    CMD="${CMD} --komga.database.file="${KOMGA_CONFIGDIR}/database.sqlite""
    CMD="${CMD} --server.port="$ui_port""

    log_msg "CMD = ${CMD}"
    log_msg "Starting process ..."
    # run cmd to start process
    cd ${TRIM_APPDEST}
    nohup ${CMD} 2>&1 &
    log_msg "Starting successfully"
    # write pid to pidfile
    printf "%s" "$!" > ${PID_FILE}
    # log_msg "CMD = ${CMD}"
    # log_msg "pid = $!"
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            # process not exist, delete pidfile
            rm -f "${PID_FILE}"
            log_msg "remove pid file 1"
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
        else
            log_msg "process killed... "
        fi
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0  # process exist
    else
        return 1  # process not exist
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            # Process is not running but pidfile exists - clean it up
            rm -f "${PID_FILE}"
        fi    
    fi

    return 1
}

case $1 in
start)
    # run start command. exit 0 if success, exit 1 if failed
    start_process
    ;;
stop)
    # run stop command. exit 0 if success, exit 1 if failed
    stop_process
    ;;
status)
    # check application status command. exit 0 if running, exit 3 if not running
    if status; then 
        exit 0
    else 
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac